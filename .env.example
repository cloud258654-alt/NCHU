# BI-RMP root environment template.
# Copy this file to .env for local development.
# Keep real secrets only in .env, deployment secret managers, or n8n credentials.

# Backend database / Supabase settings
DATABASE_URL=

# Shared secret for n8n -> BI-RMP backend requests.
# Use the same long random value in the backend and n8n runtime.
BI_RMP_INTERNAL_API_KEY=change-this-internal-api-key

# LINE reputation report settings.
# Read every row from the existing shared relation without modifying its schema.
BI_RMP_ENRICHED_REVIEW_TABLE=public.reviews_enriched
BI_RMP_DEFAULT_BUSINESS_NAME=文章牛肉湯

# Backend crawler runtime settings
HEADLESS=True
SCROLL_DELAY=3.0
SCROLL_ROUNDS=5
STORAGE_STATE_PATH=storage_state.json
THREADS_STORAGE_STATE_PATH=storage/threads_state.json

# LINE-triggered reputation crawler. One full business job per backend instance
# prevents multiple Chromium-heavy jobs from competing for memory.
BI_RMP_REPUTATION_CRAWL_ENABLED=true
BI_RMP_REPUTATION_CRAWL_TIMEOUT_SECONDS=600
BI_RMP_REPUTATION_CRAWL_MAX_MINUTES=2
BI_RMP_REPUTATION_CRAWL_PTT_MAX_MINUTES=2
BI_RMP_REPUTATION_CRAWL_GOOGLE_MAPS_MAX_MINUTES=3
BI_RMP_REPUTATION_CRAWL_THREADS_MAX_MINUTES=3
BI_RMP_REPUTATION_CRAWL_BROWSER_CONCURRENCY=2
BI_RMP_REPUTATION_CRAWL_PERSISTENCE_GRACE_SECONDS=30
BI_RMP_REPUTATION_CRAWL_MAX_RESULTS=50
BI_RMP_REPUTATION_CRAWL_PLATFORM=all
BI_RMP_REPUTATION_CRAWL_MAX_ACTIVE_JOBS=1

SEARCH_ENGINE=auto
SEARXNG_BASE_URL=http://127.0.0.1:8080
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# Backend writes must use DATABASE_URL or SUPABASE_SERVICE_ROLE_KEY.
# Do not use SUPABASE_ANON_KEY for server-side inserts/upserts.

# n8n local Docker runtime settings
# Used by: docker compose --env-file .env -f infra/n8n/docker-compose.yml up -d
COMPOSE_PROJECT_NAME=bi-rmp-n8n
N8N_IMAGE=docker.n8n.io/n8nio/n8n
N8N_HOST_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_PROXY_HOPS=0
N8N_SECURE_COOKIE=false

# n8n 2.x blocks $env/process.env access in Code nodes by default.
# Required by the LINE signature verification Code node.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Allow the LINE signature verification Code node to use Node's crypto module.
NODE_FUNCTION_ALLOW_BUILTIN=crypto

# Use a fixed key per environment. Do not change it after n8n credentials are created.
N8N_ENCRYPTION_KEY=change-this-to-a-fixed-local-dev-encryption-key

GENERIC_TIMEZONE=Asia/Taipei
TZ=Asia/Taipei

N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-this-local-password

# Production deploy script only.
# Set this to the existing production n8n workflow ID so imports overwrite the
# same workflow instead of creating duplicates. If omitted, the deploy script
# attempts to discover one existing workflow with the same repository workflow
# name or webhook path, but setting the fixed ID is safer.
N8N_WORKFLOW_ID=

# Optional owner routing for n8n imports. Set at most one.
N8N_PROJECT_ID=
N8N_USER_ID=

# BI-RMP backend endpoint from inside the n8n container.
# host.docker.internal is mapped to the Docker host gateway by the Compose file.
BI_RMP_BACKEND_BASE_URL=http://host.docker.internal:8000

# Public HTTPS registration page opened by the LINE Flex Message button.
# Optional non-LIFF fallback. Leave empty when LINE_LIFF_ID is configured.
BI_RMP_REGISTRATION_URL=

# LIFF app ID used by the Flex button and the registration page. Required on GCP.
LINE_LIFF_ID=

# LINE Login channel ID used to verify LIFF ID tokens. Required on GCP.
LINE_LOGIN_CHANNEL_ID=

# LINE Messaging API secrets. Keep real values only in .env or n8n credentials.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
