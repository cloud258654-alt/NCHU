# BI-RMP shared staging environment template.
# Copy to the staging host runtime env file and fill secrets there only.

APP_ENV=staging
SUPABASE_PROJECT_REF=qlhykeeyjaoikczoambe
SUPABASE_URL=https://qlhykeeyjaoikczoambe.supabase.co
DATABASE_URL=
ALLOW_DATABASE_WRITES=true
ALLOW_PRODUCTION_DB=false

BI_RMP_INTERNAL_API_KEY=
BI_RMP_BACKEND_BASE_URL=http://host.docker.internal:8101
BI_RMP_LINE_ALLOWED_USER_IDS=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=

N8N_HOST=localhost
N8N_HOST_PORT=5679
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://127.0.0.1:5679/
N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=
N8N_DB_NAME=n8n_staging
N8N_DB_USER=n8n_staging
N8N_DB_PASSWORD=
N8N_WORKFLOW_ID=
COMPOSE_PROJECT_NAME=bi-rmp-staging-n8n
STAGING_N8N_CONTAINER=bi-rmp-staging-n8n
STAGING_N8N_POSTGRES_CONTAINER=bi-rmp-staging-n8n-postgres

GENERIC_TIMEZONE=Asia/Taipei
TZ=Asia/Taipei
