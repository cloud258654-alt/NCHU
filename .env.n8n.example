# BI-RMP n8n local runtime environment template.
# Copy to .env.n8n or merge into .env for local Docker Compose usage.
# Do not commit real secrets.

APP_ENV=staging
DATABASE_TARGET=staging
ALLOW_PRODUCTION_DB=false

SUPABASE_PROJECT_NAME=BI-RMP-V2-STAGING
SUPABASE_PROJECT_REF=qlhykeeyjaoikczoambe
SUPABASE_URL=https://qlhykeeyjaoikczoambe.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

COMPOSE_PROJECT_NAME=bi-rmp-n8n
N8N_IMAGE=docker.n8n.io/n8nio/n8n
N8N_HOST_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_PROXY_HOPS=0
N8N_SECURE_COOKIE=false
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
NODE_FUNCTION_ALLOW_BUILTIN=crypto
N8N_ENCRYPTION_KEY=
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=
GENERIC_TIMEZONE=Asia/Taipei
TZ=Asia/Taipei

BI_RMP_BACKEND_BASE_URL=http://host.docker.internal:8000
BI_RMP_CORE_API_URL=http://127.0.0.1:8000
DASHBOARD_ML_API_URL=http://127.0.0.1:8010
